<?xml version="1.0" encoding="UTF-8"?>
<!--
  settings.xml — credenciales para resolver `com.parkvision:parkvision-shared`
  desde GitHub Packages (repo TesisProject/cloud-shared).

  Uso local:   ./mvnw -s settings.xml <goal>
  Requiere dos variables de entorno:
    GITHUB_ACTOR  = tu usuario de GitHub (cualquiera con acceso de lectura al paquete)
    GITHUB_TOKEN  = un PAT con el scope `read:packages`
  En CI, GitHub las inyecta automáticamente (github.actor / secrets.GITHUB_TOKEN).
  En el build de Docker el token llega como build-secret (ver Dockerfile).
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">
  <servers>
    <server>
      <id>github-parkvision-shared</id>
      <username>${env.GITHUB_ACTOR}</username>
      <password>${env.GITHUB_TOKEN}</password>
    </server>
  </servers>
</settings>
